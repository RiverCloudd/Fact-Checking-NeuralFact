DEEPSEEK_API_KEY=your_deepseek_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# Retrieval
USE_QDRANT=false
SERPER_TOP_K=3
MAX_EVIDENCES_PER_CLAIM=3
MAX_PARALLEL_RETRIEVAL=3

# Optional Qdrant
QDRANT_TOP_K=2
QDRANT_SCORE_THRESHOLD=0.75

# Pipeline behavior
MAX_CLAIMS=2
USE_LLM_DECOMPOSE=true
USE_LLM_CHECKWORTHY=false
DECOMPOSE_MAX_RETRIES=1
CHECKWORTHY_MAX_RETRIES=1
VERIFY_MAX_RETRIES=1
RETRIEVE_RETRY_ENABLED=false

# Timeouts / model
SERPER_TIMEOUT_SECONDS=4
LLM_TIMEOUT_SECONDS=12
LLM_MAX_TOKENS=350
LLM_TEMPERATURE=0

# IMPORTANT source-count knobs:
# - SERPER_TOP_K: so ket qua toi da Serper tra ve cho moi claim.
# - MAX_EVIDENCES_PER_CLAIM: gioi han so evidence duoc GIU LAI sau retrieve.
# - VERIFY_EVIDENCES_PER_CLAIM: so evidence dua vao verify TRONG MOT LAN GOI LLM.
# - VERIFY_EVIDENCE_MAX_CHARS: gioi han do dai moi evidence de giam token/latency.
# Neu muon verify 1 lan voi nhieu nguon va van nhanh, dat:
#   SERPER_TOP_K=3
#   MAX_EVIDENCES_PER_CLAIM>=3
#   VERIFY_EVIDENCES_PER_CLAIM=2 hoac 3
VERIFY_EVIDENCES_PER_CLAIM=2
VERIFY_EVIDENCE_MAX_CHARS=220

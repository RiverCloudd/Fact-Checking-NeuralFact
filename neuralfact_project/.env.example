DEEPSEEK_API_KEY=your_deepseek_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# Retrieval
SERPER_TOP_K=3
MAX_EVIDENCES_PER_CLAIM=3
MAX_PARALLEL_RETRIEVAL=3

# Pipeline behavior
MAX_CLAIMS=2
DECOMPOSE_MAX_RETRIES=1
VERIFY_MAX_RETRIES=1

# Timeouts / model
SERPER_TIMEOUT_SECONDS=4
LLM_TIMEOUT_SECONDS=12
LLM_MAX_TOKENS=350
LLM_TEMPERATURE=0

# IMPORTANT source-count knobs:
# - SERPER_TOP_K: so ket qua toi da Serper tra ve cho moi claim.
# - MAX_EVIDENCES_PER_CLAIM: gioi han so evidence duoc GIU LAI sau retrieve.
# - VERIFY_EVIDENCES_PER_CLAIM: so evidence dua vao verify TRONG MOT LAN GOI LLM.
# Neu muon verify 1 lan voi nhieu nguon va van nhanh, dat:
#   SERPER_TOP_K=3
#   MAX_EVIDENCES_PER_CLAIM>=3
#   VERIFY_EVIDENCES_PER_CLAIM=3
VERIFY_EVIDENCES_PER_CLAIM=3
